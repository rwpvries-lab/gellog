+extension SignInWithApple: ASAuthorizationControllerPresentationContextProviding {
+    public func presentationAnchor(for controller: ASAuthorizationController) -> ASPresentationAnchor {
+        // Prefer the Capacitor host window; fall back to the foreground scene's key window.
+        // iPad requires a real anchor or ASAuthorizationController never presents the sheet.
+        if let window = self.bridge?.viewController?.view.window {
+            return window
+        }
+        let scenes = UIApplication.shared.connectedScenes.compactMap { $0 as? UIWindowScene }
+        let activeScene =
+            scenes.first { $0.activationState == .foregroundActive } ?? scenes.first
+        if let window = activeScene?.windows.first(where: \.isKeyWindow) ?? activeScene?.windows.first {
+            return window
+        }
+        return UIWindow()
+    }
